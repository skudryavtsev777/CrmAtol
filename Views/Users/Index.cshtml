@model IEnumerable<CrmAtol.Models.UserRoleViewModel>
@{
    ViewData["Title"] = "Управление пользователями";
}

<h1>Управление пользователями</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Создать пользователя</a>
</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Email</th>
            <th>Роль</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Email</td>
                <td>@item.CurrentRole</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-warning">Изменить роль</a>
                    <form asp-action="Delete" asp-route-id="@item.UserId" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Удалить пользователя @item.Email?')">Удалить</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>