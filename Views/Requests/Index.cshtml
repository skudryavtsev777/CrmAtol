@model IEnumerable<CrmAtol.Models.Request>
@using CrmAtol.Models

@{
    ViewData["Title"] = "Заявки";
}

<h1>Заявки</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Создать заявку</a>
</p>

<!-- Форма фильтрации -->
<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Статус</label>
                <select name="status" class="form-select">
                    <option value="">Все</option>
                    @foreach (var status in Enum.GetValues(typeof(Enums.RequestStatus)))
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Приоритет</label>
                <select name="priority" class="form-select">
                    <option value="">Все</option>
                    @foreach (var priority in Enum.GetValues(typeof(Enums.RequestPriority)))
                    {
                        <option value="@priority">@priority</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Исполнитель</label>
                <input name="assignedTo" class="form-control" placeholder="Введите имя" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">Применить</button>
                <a asp-action="Index" class="btn btn-secondary">Сбросить</a>
            </div>
        </form>
    </div>
</div>

<!-- Остальная таблица остается без изменений -->

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Номер</th>
            <th>Дата</th>
            <th>Клиент</th>
            <th>Тема</th>
            <th>Приоритет</th>
            <th>Статус</th>
            <th>Исполнитель</th>
            <th>Срок реакции</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            string rowClass = "";
            if (item.Status == Enums.RequestStatus.Новая)
                rowClass = "table-warning";
            else if (item.Status == Enums.RequestStatus.Закрыта)
                rowClass = "table-success";

            <tr class="@rowClass">
                <td>@item.Number</td>
                <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@item.Client?.Name</td>
                <td>@item.Subject</td>
                <td>
                    @if (item.Priority == Enums.RequestPriority.Высокий)
                    {
                        <span class="badge bg-danger">@item.Priority</span>
                    }
                    else if (item.Priority == Enums.RequestPriority.Критический)
                    {
                        <span class="badge bg-dark">@item.Priority</span>
                    }
                    else if (item.Priority == Enums.RequestPriority.Средний)
                    {
                        <span class="badge bg-warning">@item.Priority</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@item.Priority</span>
                    }
                </td>
                <td>@item.Status</td>
                <td>@(item.AssignedToUser?.UserName ?? "Не назначен")</td>
                <td>
                    @if (item.DeadlineReaction < DateTime.Now && item.Status != Enums.RequestStatus.Закрыта)
                    {
                        <span class="text-danger">Просрочен! @item.DeadlineReaction.ToString("dd.MM.yyyy HH:mm")</span>
                    }
                    else
                    {
                        @item.DeadlineReaction.ToString("dd.MM.yyyy HH:mm")
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>