@model CrmAtol.Models.Request

@{
    ViewData["Title"] = "Удаление заявки";
}

<h1>Удаление заявки</h1>

<div class="alert alert-danger">
    <h3>Вы уверены, что хотите удалить эту заявку?</h3>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Номер</dt>
        <dd class="col-sm-10">@Model.Number</dd>

        <dt class="col-sm-2">Дата</dt>
        <dd class="col-sm-10">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>

        <dt class="col-sm-2">Клиент</dt>
        <dd class="col-sm-10">@Model.Client?.Name</dd>

        <dt class="col-sm-2">Тема</dt>
        <dd class="col-sm-10">@Model.Subject</dd>

        <dt class="col-sm-2">Статус</dt>
        <dd class="col-sm-10">@Model.Status</dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Удалить" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Отмена</a>
    </form>
</div>